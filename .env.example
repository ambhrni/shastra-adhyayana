# ============================================================
# shastra-adhyayana — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Supabase ---
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — only needed for the ingestion script (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Site URL (used for absolute URL resolution in edge functions, e.g. OG image) ---
NEXT_PUBLIC_SITE_URL=https://www.tattvasudha.org

# --- Anthropic ---
# Found in: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
